# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/.vite/

# Environment variables
backend/.env
*.env.local

# Database and uploaded files
backend/data/
backend/uploads/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# Temp
tmp/
temp/
data/plc_control.db
data/plc_control.db-shm
data/plc_control.db-wal
data/backups/

# Downloaded font assets (restored by `npm install` postinstall script)
backend/src/assets/fonts/*.ttf
backend/src/assets/fonts/*.otf

# ─── Python / hardware-services ───────────────────────────────────────────────

# Virtual environment
hardware-services/venv/

# Python bytecode cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Generated test reports (Excel/CSV output from battery tests)
hardware-services/reports/

# Dynamic station registry (auto-created at runtime, not source code)
backend/station_registry.json

# Python tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
